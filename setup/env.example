# ============================================================
# SEO Content Writer — Environment Variables
# Copy to .env and fill in all values
# Add these to n8n's environment settings (Settings > Variables)
# ============================================================

# --- Supabase ---
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SERVICE_ROLE_KEY     # Settings > API > service_role
SUPABASE_ANON_KEY=YOUR_ANON_KEY                # Settings > API > anon public

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# Note: keyword/SERP research belongs to the SEO team's (future) SEO agent.
# The content writing pipeline does not call any search API.

# --- Google (Docs + Gmail OAuth) ---
# Configure via n8n credential manager — no env var needed
# Credential name: "Google OAuth2 account"

# --- n8n Self-hosted ---
N8N_HOST=http://localhost:5678                 # your n8n instance URL

# --- Website IDs (auto-seeded by supabase-schema.sql) ---
# After running schema, query: SELECT id, slug FROM websites;
# Then replace these below:
GRYNOW_WEBSITE_ID=
MYWALL_WEBSITE_ID=
IGYGROW_WEBSITE_ID=

# --- Deploy Agent (content-deploy-agent webhook) ---
# n8n (Docker) reaches the deploy agent on the host via host.docker.internal.
# DEPLOY_TOKEN must match DEPLOY_TOKEN in the deploy-agent's .env.
DEPLOY_WEBHOOK_URL=http://host.docker.internal:7331/deploy
DEPLOY_TOKEN=

# --- Inter-workflow Webhook IDs ---
# After importing all workflows in n8n, copy each webhook URL here
# These are used in the SETUP.md configuration step
RESEARCH_WEBHOOK_URL=http://localhost:5678/webhook/REPLACE_AFTER_IMPORT
STRATEGY_WEBHOOK_URL=http://localhost:5678/webhook/REPLACE_AFTER_IMPORT
WRITER_WEBHOOK_URL=http://localhost:5678/webhook/REPLACE_AFTER_IMPORT
MEMORY_WEBHOOK_URL=http://localhost:5678/webhook/REPLACE_AFTER_IMPORT

# --- SEO Team Email (review notifications) ---
SEO_TEAM_EMAIL=seo@yourcompany.com
REVIEW_FORM_URL=http://localhost:5678/form/REPLACE_AFTER_IMPORT
