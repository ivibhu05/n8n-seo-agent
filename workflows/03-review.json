    {
      "id": "rev-rework-memory",
      "name": "Rework: Trigger Memory",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1440, 440],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Config').first().json.MEMORY_WEBHOOK_URL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({ type: 'rework', content_version_id: $('Config').first().json.version_id, request_id: $('Config').first().json.request_id, feedback: { feedback_text: $('Config').first().json.feedback_text, category: $('Config').first().json.category, severity: $('Config').first().json.severity } }) }}"
      }
    },
    {
      "id": "rev-rework-pipeline",
      "name": "Rework: Trigger Pipeline",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1680, 440],
      "parameters": {
        "method": "POST",
        "url": "={{ $('Config').first().json.PIPELINE_WEBHOOK_URL }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ JSON.stringify({request_id: $('Config').first().json.request_id, start_from: 'write', is_rework: true, rework_feedback: { feedback_text: $('Config').first().json.feedback_text, category: $('Config').first().json.category, severity: $('Config').first().json.severity } }) }}"
      }
    },
    {
      "id": "rev-approve-deploy",
      "name": "Approve: Deploy",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1680, 160],
      "parameters": {
        "jsCode": "const fetch=(u,o={})=>new Promise((res,rej)=>{const iH=u.startsWith('https');const lib=require(iH?'https':'http');const m=u.match(/^https?:\\/\\/([^/:]+)(?::(\\d+))?(\\/[^?#]*)?(\\?[^#]*)?/);if(!m)return rej(new Error('Bad URL: '+u));const body=o.body||null;const req=lib.request({hostname:m[1],port:m[2]?+m[2]:(iH?443:80),path:(m[3]||'/')+(m[4]||''),method:o.method||'GET',headers:{...(o.headers||{}),...(body?{'Content-Length':Buffer.byteLength(body)}:{})}},r=>{let d='';r.on('data',c=>d+=c);r.on('end',()=>res({ok:r.statusCode<300,status:r.statusCode,json:()=>Promise.resolve(JSON.parse(d||'null')),text:()=>Promise.resolve(d)}));});req.on('error',rej);if(body)req.write(body);req.end();});\n\nconst cfg = $('Config').first().json;\nconst sbUrl = cfg.SUPABASE_URL, sbKey = cfg.SUPABASE_SERVICE_KEY;\nconst sbAuth = { apikey: sbKey, Authorization: 'Bearer ' + sbKey };\n\n// Approved markdown for this version\nconst vr = await fetch(`${sbUrl}/rest/v1/content_versions?id=eq.${cfg.version_id}&select=content_markdown`, { headers: sbAuth });\nconst ver = (await vr.json())[0] || {};\nconst markdown = ver.content_markdown || '';\n\n// Request → website slug (= deploy target) + topic for the commit message\nconst rr = await fetch(`${sbUrl}/rest/v1/content_requests?id=eq.${cfg.request_id}&select=topic,content_type,websites(slug,name)`, { headers: sbAuth });\nconst req = (await rr.json())[0] || {};\nconst slug = req.websites && req.websites.slug;\n\nif (!markdown) throw new Error('Deploy skipped: no content_markdown for version ' + cfg.version_id);\nif (!slug) throw new Error('Deploy skipped: no website slug for request ' + cfg.request_id);\nif (!cfg.DEPLOY_WEBHOOK_URL) throw new Error('Deploy skipped: DEPLOY_WEBHOOK_URL not configured');\n\nconst headers = {'Content-Type': 'application/json','x-deploy-token': cfg.DEPLOY_TOKEN};\nconsole.log('DEPLOY_WEBHOOK_URL:', cfg.DEPLOY_WEBHOOK_URL); console.log('DEPLOY_TOKEN:', cfg.DEPLOY_TOKEN); console.log('HEADERS:', headers);\nconst dr = await fetch(cfg.DEPLOY_WEBHOOK_URL, {\n  method: 'POST', headers,\n  body: JSON.stringify({ target: slug, markdown, message: `Publish: ${req.topic || 'post'} [n8n→deploy-agent]` })\n});\nconst result = await dr.json();\nif (!dr.ok || !result || result.ok === false) {\n  throw new Error('Deploy failed: HTTP ' + dr.status + ' ' + JSON.stringify(result));\n}\nreturn [{ json: { deployed: true, target: slug, repoPath: result.repoPath, url: (result.committed && result.committed.url) || null } }];"
      }
    }
  ],
